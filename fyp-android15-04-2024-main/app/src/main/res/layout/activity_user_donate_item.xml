<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDonateItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:text="Donation"
            android:textSize="@dimen/_25ssp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/tvItemPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_3sdp"
            android:text="Item Photo"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvDonateItem"
            app:layout_constraintStart_toStartOf="parent"
            />

        <HorizontalScrollView
            android:id="@+id/horizontalScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_3sdp"
           >

            <LinearLayout
                android:id="@+id/imageLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imageView1"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/image_border"
                    android:padding="30dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/addone" />

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/image_border"
                    android:padding="30dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/addone" />

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/image_border"
                    android:padding="30dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/addone" />

                <ImageView
                    android:id="@+id/imageView4"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/image_border"
                    android:padding="30dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/addone" />

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/image_border"
                    android:padding="30dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/addone" />


            </LinearLayout>

        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Item Name"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/horizontalScrollView"
            app:layout_constraintStart_toStartOf="parent"
             />

        <EditText
            android:id="@+id/itemName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:background="@drawable/background_input_state"
            android:imeOptions="actionNext"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingStart="@dimen/_16sdp"
            android:paddingEnd="@dimen/_16sdp"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_13ssp"
          />

        <TextView
            android:id="@+id/tvItemType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Item Type"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"

            />


        <Spinner
            android:id="@+id/spinnerItemType"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:hint="物品描述"
            android:layout_marginTop="@dimen/_5sdp"
            android:background="@drawable/background_input"
          />


        <TextView
            android:id="@+id/tvCondition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Condition"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"

            />

        <Spinner
            android:id="@+id/spinnerCondition"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:hint="物品描述"
            android:layout_marginTop="@dimen/_5sdp"
            android:background="@drawable/background_input"
           />


        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Description"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"

            />

        <EditText
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_100sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:background="@drawable/background_input_state"
            android:imeOptions="actionNext"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:paddingStart="@dimen/_16sdp"
            android:paddingEnd="@dimen/_16sdp"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_13ssp"
            android:gravity="top|start"
            android:lines="10"
            android:minLines="1"
            android:maxLines="10"
           />

        <TextView
            android:id="@+id/tvOptionalDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Optional Details"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"
             />

        <TextView
            android:id="@+id/tvShowOrHide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Show"
            android:textColor="@color/green"
            android:textSize="@dimen/_15ssp"
            android:drawableRight="@drawable/ic_arrow_down"
            android:drawablePadding="@dimen/_5sdp"
            android:onClick="showOrHide"
             />

        <TextView
            android:id="@+id/tvOptionalDetailsInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:text="You can choose not to fill it out, but providing the information makes it easier for others to understand the items you donated."
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_10ssp"
            android:textStyle="bold"
            />



        <LinearLayout
            android:id="@+id/optionalDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


        </LinearLayout>




        <TextView
            android:id="@+id/tvDealMethod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_20sdp"
            android:text="Deal Method"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold"
            />

        <LinearLayout
            android:id="@+id/rdgDealMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
       >

            <TextView
                android:id="@+id/tvMeetUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meet-up"/>

            <CheckBox
                android:id="@+id/ckbMeetUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="toggleDealMethodEditTextVisibility"
                />

            <EditText
                android:id="@+id/etMeetUp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_45sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/background_input_state"
                android:imeOptions="actionNext"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/_13ssp"
                android:visibility="gone"/>


            <TextView
                android:id="@+id/tvMailingAndDelivery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20sdp"
                android:text="Mailing And Delivery"/>

            <CheckBox
                android:id="@+id/ckbMailingAndDelivery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="toggleDealMethodEditTextVisibility"
                />

            <EditText
                android:id="@+id/etMailingAndDelivery"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_45sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/background_input_state"
                android:imeOptions="actionNext"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/_13ssp"
                android:visibility="gone"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnListIt"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="List it!"
            style="@style/GreenButton"
            android:layout_marginTop="@dimen/_20sdp"
            android:onClick="listItems"
            app:layout_constraintTop_toBottomOf="@id/rdgDealMethod"
            app:layout_constraintStart_toStartOf="parent"/>

    </LinearLayout>

</ScrollView>