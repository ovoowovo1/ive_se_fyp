<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#FFFFFF" /> <!-- Background color -->
    <corners android:radius="8dp" /> <!-- Rounded corners -->

    <!-- Outer border -->
    <stroke
        android:width="2dp"
        android:color="#353535" /> <!-- Outer border color -->

    <!-- Inner border -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" /> <!-- Inner border color -->
</shape>